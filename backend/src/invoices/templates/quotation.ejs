<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 40px;
      color: #111827;
    }

    .header {
      border-bottom: 4px solid #f97316;
      padding-bottom: 15px;
      margin-bottom: 30px;
    }

    .brand {
      font-size: 28px;
      font-weight: bold;
      color: #111827;
    }

    .muted {
      color: #6b7280;
      font-size: 13px;
    }

    .section {
      margin-top: 25px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    th {
      background: #111827;
      color: white;
      padding: 10px;
      text-align: left;
    }

    td {
      border: 1px solid #e5e7eb;
      padding: 10px;
    }

    .totals {
      margin-top: 25px;
      width: 300px;
      margin-left: auto;
    }

    .totals div {
      display: flex;
      justify-content: space-between;
      padding: 7px 0;
    }

    .grand {
      font-size: 18px;
      font-weight: bold;
      border-top: 2px solid #111827;
      margin-top: 8px;
      padding-top: 10px;
    }

    .footer {
      margin-top: 45px;
      font-size: 12px;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
      padding-top: 15px;
    }
  </style>
</head>

<body>
  <div class="header">
    <div class="brand">CHOMELEA WELDING & FABRICATION</div>
    <div class="muted">Kitengela, Kenya</div>
    <div class="muted">Quotation Document</div>
  </div>

  <h2>Quotation</h2>

  <p><strong>Quotation No:</strong> <%= quotation.quotationNumber %></p>
  <p><strong>Status:</strong> <%= quotation.status %></p>
  <p><strong>Date:</strong> <%= new Date(quotation.createdAt).toLocaleDateString() %></p>

  <div class="section">
    <h3>Customer Details</h3>
    <p><strong>Name:</strong> <%= quotation.customer?.fullName || "" %></p>
    <p><strong>Phone:</strong> <%= quotation.customer?.phone || "" %></p>
    <p><strong>Location:</strong> <%= quotation.customer?.location || "" %></p>
  </div>

  <div class="section">
    <h3>Items</h3>

    <table>
      <thead>
        <tr>
          <th>Item</th>
          <th>Qty</th>
          <th>Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>

      <tbody>
        <% quotation.items.forEach(item => { %>
          <tr>
            <td><%= item.itemName %></td>
            <td><%= item.quantity %></td>
            <td>KES <%= item.unitPrice.toLocaleString() %></td>
            <td>KES <%= item.total.toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="totals">
    <div>
      <span>Labor:</span>
      <span>KES <%= quotation.laborCost.toLocaleString() %></span>
    </div>

    <div>
      <span>Transport:</span>
      <span>KES <%= quotation.transportCost.toLocaleString() %></span>
    </div>

    <div>
      <span>Subtotal:</span>
      <span>KES <%= quotation.subtotal.toLocaleString() %></span>
    </div>

    <div>
      <span>Tax:</span>
      <span>KES <%= quotation.tax.toLocaleString() %></span>
    </div>

    <div class="grand">
      <span>Grand Total:</span>
      <span>KES <%= quotation.grandTotal.toLocaleString() %></span>
    </div>
  </div>

  <div class="section">
    <h3>Notes</h3>
    <p><%= quotation.notes || "No notes provided." %></p>
  </div>

  <div class="footer">
    Thank you for choosing CHOMELEA Welding & Fabrication. This quotation is subject to confirmation before production begins.
  </div>
</body>
</html>